{
    "name": "vacuumtube",
    "version": "1.6.4",
    "description": "YouTube for TV, on your PC",
    "main": "index.js",
    "scripts": {
        "start": "electron .",
        "linux:build": "electron-builder --linux rpm"
    },
    "keywords": [],
    "author": "shy (shy@shy.rocks)",
    "license": "MIT",
    "build": {
        "appId": "rocks.shy.VacuumTube",
        "productName": "VacuumTube",
        "artifactName": "VacuumTube-${arch}.${ext}",
        "linux": {
            "icon": "./assets/icon.svg",
            "synopsis": "Watch and explore videos on YouTube",
            "category": "AudioVideo",
            "desktop": {
                "entry": {
                    "Name": "VacuumTube",
                    "Type": "Application",
                    "Categories": "AudioVideo;",
                    "Keywords": "YouTube;YT;"
                }
            },
            "maintainer": "elytraViii@gmail.com",
            "target": [
                {
                    "target": "rpm",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ]
        },
        "publish": {
            "provider": "github",
            "owner": "elytraVIII",
            "repo": "VacuumTube-rpm"
        }
    },
    "devDependencies": {
        "electron": "^39.4.0",
        "electron-builder": "^26.0.12"
    },
    "dependencies": {
        "chokidar": "^5.0.0",
        "electron-updater": "^6.8.3",
        "minimist": "^1.2.8",
        "sponsorblock-api": "^0.2.4",
        "string-argv": "^0.3.2",
        "tseep": "^1.3.1"
    }
}
